{
  "manifest_version": 3,
  "name": "anki-fox YouTube Timestamp",
  "version": "1.0",
  "description": "Captures exact YouTube playback timestamps for anki-fox flashcard generation.",
  "permissions": [],
  "host_permissions": ["http://localhost:5789/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {}
}
